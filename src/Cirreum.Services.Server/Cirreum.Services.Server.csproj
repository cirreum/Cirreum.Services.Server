<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<RootNamespace>Cirreum</RootNamespace>
		<Description>Service library for Cirreum ASP.NET servers. Absorbs the per-source Invocation packages (HTTP, WebSocket, SignalR) so a single package owns the framework's server-side invocation surface.</Description>
		<PackageTags>cirreum;infrastructure;services;server;invocation;websocket;signalr</PackageTags>
	</PropertyGroup>

	<ItemGroup>
		<!--
			Service library composing over the server spine. References the foundation directly:
			Cirreum.Common carries the Invocation abstractions (IInvocationContext /
			IInvocationConnection / IConnectionEstablishmentContributor) and Cirreum.Kernel
			carries AuthenticationContextKeys + the auth events.
		-->
		<ProjectReference Include="..\..\..\..\Base\Cirreum.Kernel\src\Cirreum.Kernel\Cirreum.Kernel.csproj" />
		<ProjectReference Include="..\..\..\..\Common\Cirreum.Common\src\Cirreum.Common\Cirreum.Common.csproj" />
		<ProjectReference Include="..\..\..\..\Core\Cirreum.Shared\src\Cirreum.Shared\Cirreum.Shared.csproj" />
		<ProjectReference Include="..\..\..\..\Core\Cirreum.AuthenticationProvider\src\Cirreum.AuthenticationProvider\Cirreum.AuthenticationProvider.csproj" />

		<PackageReference Include="Cirreum.Exceptions" Version="1.0.4" />
		<PackageReference Include="FluentValidation" Version="12.1.1" />
		<PackageReference Include="Polly" Version="8.6.6" />
		<PackageReference Include="Polly.Contrib.WaitAndRetry" Version="1.1.1" />

		<FrameworkReference Include="Microsoft.AspNetCore.App" />
	</ItemGroup>

	<ItemGroup>
		<Using Include="Microsoft.AspNetCore.Http" />
		<Using Include="Microsoft.Extensions.Logging" />

		<Using Include="Cirreum" />
		<Using Include="Cirreum.Exceptions" />
		<Using Include="Cirreum.FileSystem" />
	</ItemGroup>

</Project>
